# Copy to .env for local dev, or set these as Railway service variables.
# NOTE: the app reads config via st.secrets. Locally, put the same values in
# .streamlit/secrets.toml; on Railway, start.sh generates secrets.toml from these.

# --- Required: Supabase (database) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-publishable-key

# --- Email (Gmail SMTP) ---
SMTP_EMAIL=youraddress@churchgate.com
SMTP_PASSWORD=your-gmail-app-password

# --- Optional integrations (leave blank if unused) ---
OPENAI_API_KEY=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
ASANA_PERSONAL_TOKEN=
ASANA_WORKSPACE_ID=
GOOGLE_CALENDAR_API_KEY=
